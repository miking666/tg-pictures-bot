BOT_TOKEN=your_telegram_bot_token
GEMINI_API_KEY=your_gemini_api_key

# Optional overrides
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_AUDIO_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
DATA_DIR=.data
# BUDGET_FILE_PATH=.data/budget.json
# FSM_STORAGE_PATH=.data/fsm_storage.json
CARD_FONT_PATH=fonts/LiberationSans-Bold.ttf
CARD_IMAGE_SIZE=1024
MAX_GREETING_LENGTH=350
MAX_BUDGET_USD=3.0
IMAGE_GENERATION_COST=0.10
ADMIN_CHAT_ID=

# Proxy for Telegram Bot API (if api.telegram.org is blocked)
# Formats: socks5://host:port, socks5://user:pass@host:port, http://host:port
# Requires: pip install aiohttp-socks (for SOCKS5)
TELEGRAM_PROXY=
